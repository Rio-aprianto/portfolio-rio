{
  "version": 2,
  "builds": [
    {
      "src": "api/index.php",
      "use": "vercel-php"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/images/(.*)",
      "dest": "public/images/$1"
    },
    {
      "src": "/favicon.ico",
      "dest": "public/favicon.png"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.php"
    }
  ]
}
