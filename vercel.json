{
  "version": 2,
  "builds": [
    {
      "src": "api/index.php",
      "use": "@vercel/php"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/images/(.*)",
      "destination": "/public/images/$1"
    },
    {
      "source": "/favicon.ico",
      "destination": "/public/favicon.png"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.php"
    }
  ]
}
